func _update_palette() -> void:
	var shader := load("res://scripts/palette_swap.gdshader") as Shader
	for i in range(get_child_count()):
		var area_node := get_child(i)
		if not area_node is Node2D:
			continue

		var theme: Palette.WorldTheme
		var scenery: Palette.SceneryType
		if i == 0:
			theme = world_theme
			scenery = scenery_type
		elif i == 1:
			theme = subarea_1_theme
			scenery = subarea_1_scenery
		elif i == 2:
			theme = subarea_2_theme
			scenery = subarea_2_scenery
		else:
			continue

		for child in area_node.get_children():
			if child is TileMapLayer:
				var sprite_type: int = child.get(&"sprite_type")
				var pal_id: int = Palette.PALETTE_TABLE[sprite_type][theme]
				if sprite_type == 3 and Palette.SCENERY_OVERRIDE.has(scenery):
					pal_id = Palette.SCENERY_OVERRIDE[scenery]
				var mat := child.material as ShaderMaterial
				if mat == null:
					mat = ShaderMaterial.new()
					mat.shader = shader
					child.material = mat
				mat.set_shader_parameter("palette_id", pal_id)
	print("[LevelBuilder] Palettes updated")


func _clear_level() -> void:
	for i in range(get_child_count() - 1, -1, -1):
		var child := get_child(i)
		remove_child(child)
		child.free()
	print("[LevelBuilder] Cleared all children")


func _build_area(parent: Node2D, grid: Array, rows: int, cols: int,
		theme: Palette.WorldTheme, scenery: Palette.SceneryType) -> Dictionary:
	var root := get_tree().edited_scene_root
	var shader := load("res://scripts/palette_swap.gdshader") as Shader
	var pal_script := load("res://scripts/palette_swap.gd") as Script

	var layers: Dictionary = {}
	for def in LAYER_DEFS:
		var key: StringName = def[0]
		var display: String = def[1]
		var tileset_path: String = def[2]
		var sprite_type: int = def[3]
		var pal_id: int = Palette.PALETTE_TABLE[sprite_type][theme]
		if sprite_type == 3 and Palette.SCENERY_OVERRIDE.has(scenery):
			pal_id = Palette.SCENERY_OVERRIDE[scenery]

		var layer := TileMapLayer.new()
		layer.name = display
		layer.tile_set = load(tileset_path)

		var mat := ShaderMaterial.new()
		mat.shader = shader
		mat.set_shader_parameter("palette_id", pal_id)
		layer.material = mat

		layer.set_script(pal_script)
		layer.set(&"sprite_type", sprite_type)

		parent.add_child(layer)
		layer.owner = root
		layers[key] = layer

	var scenes_node := Node2D.new()
	scenes_node.name = "Scenes"
	parent.add_child(scenes_node)
	scenes_node.owner = root

	var placed_tiles := 0
	var placed_scenes := 0
	var unknown: Dictionary = {}

	for row_idx in range(rows):
		var row_data: Array = grid[row_idx]
		for col_idx in range(cols):
			var mid: int = int(row_data[col_idx])
			if mid == 0:
				continue
			if not METATILE_MAP.has(mid):
				unknown[mid] = unknown.get(mid, 0) + 1
				continue

			var entry = METATILE_MAP[mid]
			if entry is StringName or entry is String:
				var scene := load(str(entry)) as PackedScene
				if scene:
					var inst := scene.instantiate()
					inst.position = Vector2(col_idx * METATILE_PX, row_idx * METATILE_PX)
					scenes_node.add_child(inst)
					inst.owner = root
					placed_scenes += 1
			elif entry is Array and entry.size() == 2 and (entry[0] is StringName or entry[0] is String):
				var scene := load(str(entry[0])) as PackedScene
				if scene:
					var inst := scene.instantiate()
					inst.position = Vector2(col_idx * METATILE_PX, row_idx * METATILE_PX)
					var props: Dictionary = entry[1]
					for prop_name in props:
						inst.set(prop_name, props[prop_name])
					scenes_node.add_child(inst)
					inst.owner = root
					placed_scenes += 1
			elif entry is Array:
				var layer: TileMapLayer = layers[entry[2]]
				layer.set_cell(Vector2i(col_idx, row_idx), 0, Vector2i(entry[0], entry[1]))
				placed_tiles += 1

	return {"tiles": placed_tiles, "scenes": placed_scenes, "unknown": unknown}


func _build_entities(parent: Node2D, entities: Array) -> int:
	var root := get_tree().edited_scene_root
	var entities_node := Node2D.new()
	entities_node.name = "Entities"
	parent.add_child(entities_node)
	entities_node.owner = root

	var placed := 0
	for entity in entities:
		var etype: String = entity["type"]
		var col: int = int(entity["col"])
		var row: int = int(entity["row"])
		if ENTITY_SCENE_MAP.has(etype):
			var entry: Array = ENTITY_SCENE_MAP[etype]
			var scene := load(entry[0]) as PackedScene
			var h: int = entry[1]
			if scene:
				var inst := scene.instantiate()
				inst.position = Vector2(col * METATILE_PX, row * METATILE_PX - h)
				if entry.size() > 2:
					var props: Dictionary = entry[2]
					for prop_name in props:
						inst.set(prop_name, props[prop_name])
				entities_node.add_child(inst)
				inst.owner = root
				placed += 1
		elif GROUP_SPAWNER_MAP.has(etype):
			var group_def: Array = GROUP_SPAWNER_MAP[etype]
			var scene := load(group_def[0]) as PackedScene
			var count: int = group_def[1]
			var h: int = group_def[2]
			if scene:
				for i in range(count):
					var inst := scene.instantiate()
					inst.position = Vector2((col + i) * METATILE_PX, row * METATILE_PX - h)
					entities_node.add_child(inst)
					inst.owner = root
					placed += 1

	return placed


func _build_level() -> void:
	if level_json_path.is_empty():
		push_error("[LevelBuilder] No level JSON path set")
		return

	var file := FileAccess.open(level_json_path, FileAccess.READ)
	if not file:
		push_error("[LevelBuilder] Cannot open: %s" % level_json_path)
		return

	var data = JSON.parse_string(file.get_as_text())
	file.close()
	if data == null:
		push_error("[LevelBuilder] Failed to parse JSON")
		return

	_clear_level()

	var root := get_tree().edited_scene_root
	var areas: Array = data["areas"]
	var all_unknown: Dictionary = {}
	var y_offset := 0.0

	# Auto-set themes from JSON area_type_name
	if areas.size() > 0:
		var main_type: String = areas[0].get("area_type_name", "overworld")
		world_theme = THEME_FROM_AREA_TYPE.get(main_type, Palette.WorldTheme.OVERWORLD)
	if areas.size() > 1:
		var sub1_type: String = areas[1].get("area_type_name", "underground")
		subarea_1_theme = THEME_FROM_AREA_TYPE.get(sub1_type, Palette.WorldTheme.UNDERGROUND)
	if areas.size() > 2:
		var sub2_type: String = areas[2].get("area_type_name", "underground")
		subarea_2_theme = THEME_FROM_AREA_TYPE.get(sub2_type, Palette.WorldTheme.UNDERGROUND)
	notify_property_list_changed()

	for i in range(areas.size()):
		var area: Dictionary = areas[i]
		var area_name: String = area.get("name", "Area_%d" % i)
		var area_rows: int = int(area["rows"])
		var area_cols: int = int(area["cols"])
		var area_type_name: String = area.get("area_type_name", "overworld")

		var theme: Palette.WorldTheme
		var scenery: Palette.SceneryType
		if i == 0:
			theme = world_theme
			scenery = scenery_type
		elif i == 1:
			theme = subarea_1_theme
			scenery = subarea_1_scenery
		elif i == 2:
			theme = subarea_2_theme
			scenery = subarea_2_scenery
		else:
			theme = THEME_FROM_AREA_TYPE.get(area_type_name, Palette.WorldTheme.OVERWORLD)
			scenery = Palette.SceneryType.DEFAULT

		var area_node := Node2D.new()
		area_node.name = area_name
		if y_offset != 0.0:
			area_node.position.y = y_offset
		add_child(area_node)
		area_node.owner = root

		var result := _build_area(area_node, area["grid"],
				area_rows, area_cols, theme, scenery)

		var entity_count := 0
		var entities: Array = area.get("entities", [])
		if entities.size() > 0:
			entity_count = _build_entities(area_node, entities)

		print("[LevelBuilder] %s: %d tiles, %d scenes, %d entities (%dx%d)" % [
				area_name, result["tiles"], result["scenes"], entity_count, area_cols, area_rows])

		for k in result["unknown"]:
			all_unknown[k] = all_unknown.get(k, 0) + result["unknown"][k]

		y_offset += AREA_ROWS * METATILE_PX + AREA_GAP

	if all_unknown.size() > 0:
		var sorted_keys := all_unknown.keys()
		sorted_keys.sort()
		for k in sorted_keys:
			print("[LevelBuilder]   unknown metatile %d  ×%d" % [k, all_unknown[k]])
