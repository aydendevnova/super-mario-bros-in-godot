@tool
extends Node2D
## Parses a level JSON file and builds it as TileMapLayers + scene instances.
## Generated by python/generate_level_builder.py

##--------------------
## DO NOT EDIT BY HAND
##--------------------

@export_file("*.json") var level_json_path: String = ""

@export var build_level: bool = false:
	set(value):
		if value and Engine.is_editor_hint():
			_build_level()

@export var clear_level: bool = false:
	set(value):
		if value and Engine.is_editor_hint():
			_clear_level()

@export var update_palette: bool = false:
	set(value):
		if value and Engine.is_editor_hint():
			_update_palette()

@export_group("Main Area")
@export var world_theme: Palette.WorldTheme = Palette.WorldTheme.OVERWORLD
@export var scenery_type: Palette.SceneryType = Palette.SceneryType.DEFAULT

@export_group("Subarea 1")
@export var subarea_1_theme: Palette.WorldTheme = Palette.WorldTheme.UNDERGROUND
@export var subarea_1_scenery: Palette.SceneryType = Palette.SceneryType.DEFAULT

@export_group("Subarea 2")
@export var subarea_2_theme: Palette.WorldTheme = Palette.WorldTheme.UNDERGROUND
@export var subarea_2_scenery: Palette.SceneryType = Palette.SceneryType.DEFAULT

